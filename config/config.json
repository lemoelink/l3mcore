{
    "updater": {
        "channel": "release"
    },
    "router": {
        "mode": "generic",
        "router_type": "embedding",
        "model_path": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
        "categories_file": "config/experts.json",
        "confidence_threshold": 0.4,
        "keyword_fallback": true,
        "softmax_temperature": 0.20,
        "scoring_weights": {
            "max_keyword": 0.4,
            "description": 0.3,
            "mean_keyword": 0.2,
            "top3_vote": 0.1
        }
    },
    "paperless": {
        "use_semantic_router": true
    },
    "tool_calling": {
        "enabled": true,
        "expert_label": "tools",
        "max_iterations": 5
    }
}
