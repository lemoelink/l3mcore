# -----------------------------------------------
# LEMoE .gitignore  –  Solo se sube producción
# -----------------------------------------------

# Entornos virtuales
venv/
.venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.pytest_cache/


private/

# Plugins (ahora es submódulo)
# plugins/

# Web / landing page (se despliega por separado en Cloudflare)
web/

# Tests (no se publican en el núcleo)
tests/
test_router.py
docker/
# Modelos binarios (demasiado grandes para Git)
*.onnx
*.gguf
*.bin
*.safetensors
*.pt
*.pth
models/*/
config/license.asc
config/.license_grace
# Datos generados en runtime
data/
logs/

# Archivos de entorno / secretos
.env
.env.*
*.secret

# Configuraciones de backup
config_old.json
experts_bak.json
*.bak
*.tmp

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
